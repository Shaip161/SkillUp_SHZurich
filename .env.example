# Anthropic
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# OpenAI / Gemini embeddings
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Adzuna
ADZUNA_APP_ID=YOUR_ADZUNA_APP_ID
ADZUNA_APP_KEY=YOUR_ADZUNA_APP_KEY

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/jobmatcher

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
CORS_ORIGINS=http://localhost:3000

# Ingestion limits (set to 0 to disable limit in production)
MAX_JOBS_PER_CATEGORY=10